# Puntos invisibles solo para construir la leyenda
geom_point(data = data.frame(
x = c(1, 1), y = c(1, 1),
grupo = c("Chn + Kor", "Arg + Esp")),
aes(x = x, y = y, color = grupo),
size = 3, alpha = 0) +
scale_color_manual(
values = c(
"Más industrializado"   = owid_azul,
"Menos industrializado" = owid_rojo,
"Chn + Kor"             = owid_azul,
"Arg + Esp"             = owid_rojo,
"Otros"                 = "gray80"
),
breaks = c("Chn + Kor", "Arg + Esp"),
labels = c(
"Chn + Kor" = sprintf("<span style='color:%s'>**Chn + Kor**</span> (más industrializado)", owid_azul),
"Arg + Esp" = sprintf("<span style='color:%s'>**Arg + Esp**</span> (menos industrializado)", owid_rojo)
),
name = NULL
) +
scale_x_log10(labels = scales::comma) +
labs(
title    = titulo_g2,
subtitle = "Eje X: índice de PBI industrial per cápita (base 100 = 1970, escala log). Eje Y: coeficiente de Gini.<br>**A** = 1970 · **B** = 1990 · **C** = 2010 · **D** = último año disponible. Líneas conectan promedio de cada par.",
caption  = "Fuente: Argendata (Fundar) y Banco Mundial (WDI).",
x = "Índice industrial per cápita (log)",
y = "Coeficiente de Gini"
) +
theme_owid() +
theme(
legend.position   = "right",
legend.text       = element_markdown(size = 9),
axis.title        = element_text(size = 9, color = "gray40")
)
print(g2)
ggsave("output/graficos/grafico_exploratorio.png", g2,
width = 11, height = 7, dpi = 300, bg = "white")
g2 <- g2 +
theme(
legend.position   = "right",
legend.text       = element_markdown(size = 9),
axis.title        = element_text(size = 9, color = "gray40"),
legend.box        = "vertical",
legend.spacing.y  = unit(0.5, "cm")
) +
guides(
color = guide_legend(order = 1, override.aes = list(size = 3, alpha = 1))
) +
annotate("text",
x = Inf, y = -Inf,
hjust = 1.1, vjust = -1,
label = "A = 1970   B = 1990   C = 2010   D = último disponible",
size = 3, color = "gray50", fontface = "italic")
print(g2)
ggsave("output/graficos/grafico_exploratorio.png", g2,
width = 13, height = 8, dpi = 300, bg = "white")
